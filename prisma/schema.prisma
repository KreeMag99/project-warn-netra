generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Notice {
  id          Int      @id @default(autoincrement())
  company     String
  date        DateTime
  announcedDate DateTime?
  verification String   @default("reported")
  affected    Int
  location    String
  sector      String?
  reason      String?
  source      String
  status      String   @default("completed")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  companySlug String?
  Company     Company? @relation(fields: [companySlug], references: [slug])

  @@map("notices")
}

model Company {
  slug          String   @id
  name          String
  fullName      String?
  sector        String?
  hqCity        String?
  hqState       String?
  employeeCount Int?
  description   String?
  careersUrl    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  notices       Notice[]
}

model Subscription {
  id                String   @id @default(cuid())
  email             String   @db.VarChar(255)
  alertType         String   // "company" or "all"
  alertValue        String   // company name or "all"
  verified          Boolean  @default(false)
  verificationToken String   @default(uuid())
  createdAt         DateTime @default(now())

  @@unique([email, alertType, alertValue])
}

model Report {
  id              String   @id @default(cuid())
  companyName     String
  affected        Int?
  location        String?
  reason          String?
  sourceUrl       String?
  reporterRole    String?  // employee, journalist, other
  details         String?
  status          String   @default("pending")  // pending, approved, rejected
  createdAt       DateTime @default(now())

  @@map("reports")
}
